# pubmed-research skill configuration
# Copy this file to ".env" and fill in the values you want.
# All fields are OPTIONAL — the skill works with none of them set, throttling
# to NCBI's unauthenticated limit of 3 requests/second.
#
# Process environment variables override values in this file, so you can also
# export any of these in your shell instead of editing here.

# --- NCBI E-utilities ---------------------------------------------------------
# An NCBI API key raises the rate limit from 3 to 10 requests/second.
# Get one (free) at: https://www.ncbi.nlm.nih.gov/account/  -> Settings -> API Key
NCBI_API_KEY=

# NCBI asks that automated tools identify themselves with a tool name and a
# contact email (courtesy parameters — not authentication).
NCBI_TOOL=pubmed-research-skill
NCBI_EMAIL=

# --- Unpaywall (optional full-text fallback) ----------------------------------
# Setting an email here ENABLES the third-stage Unpaywall fallback in
# `fulltext`, which finds open-access copies for DOIs not in PMC.
# Unpaywall requires an email on every request; any valid address works.
UNPAYWALL_EMAIL=
