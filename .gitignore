# Secrets — never commit. The skill reads .env for NCBI_API_KEY and
# UNPAYWALL_EMAIL; .env.example is the committed template.
.env
.env.*
!.env.example

# Claude Code local machine settings — not part of the published skill
.claude/settings.local.json

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/

# Output — generated CSVs are the user's, not part of the skill.
# SAMPLE/ is the exception: those are committed as documentation.
*.csv
!**/references/*.csv
!SAMPLE/*.csv

# Working notes — carried between machines by OneDrive, not part of the skill
HANDOFF.md

# OS / editor
.DS_Store
Thumbs.db
